{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Memoir",
  "version": "0.1.0",
  "identifier": "dev.memoir.desktop",
  "build": {
    "beforeDevCommand": "node ./node_modules/vite/bin/vite.js --host 127.0.0.1 --port 1420",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node ./node_modules/typescript/bin/tsc --noEmit && node ./node_modules/vite/bin/vite.js build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Memoir",
        "width": 1440,
        "height": 920,
        "minWidth": 1080,
        "minHeight": 720,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:memoir.db"]
    }
  }
}
